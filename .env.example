# === HH.ru API ===
# Публичный поиск вакансий не требует токена, но hh.ru требует явный User-Agent.
# OAuth-приложение нужно только если требуется доступ к приватным данным (резюме, отклики и т.п.)
# Регистрация приложения: https://dev.hh.ru/admin
HH_CLIENT_ID=
HH_CLIENT_SECRET=
HH_ACCESS_TOKEN=
HH_USER_AGENT=hh-parser-bot/1.0 (your-email@example.com)

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Database ===
DATABASE_URL=postgresql+asyncpg://hh:hh@db:5432/hh_pars
POSTGRES_USER=hh
POSTGRES_PASSWORD=hh
POSTGRES_DB=hh_pars

# === Parser settings ===
PARSE_INTERVAL_MINUTES=30
HH_SEARCH_TEXT=python developer
HH_SEARCH_AREA=1
LOG_LEVEL=INFO
